{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/present", "dest": "/present.html" },
    { "src": "/sw.js", "headers": { "Cache-Control": "no-cache" }, "dest": "/sw.js" },
    { "src": "/manifest.json", "headers": { "Content-Type": "application/manifest+json" }, "dest": "/manifest.json" },
    { "src": "/present-manifest.json", "headers": { "Content-Type": "application/manifest+json" }, "dest": "/present-manifest.json" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
